            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "showValue": "never",
        "rowHeight": 0.9,
        "colWidth": 0.95,
        "legend": {
          "showLegend": false,
          "displayMode": "list"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 150,
      "type": "row",
      "title": "Storage broker",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 52,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 151,
      "type": "bargauge",
