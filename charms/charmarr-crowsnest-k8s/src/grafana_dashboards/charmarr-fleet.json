        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "count(gluetun_vpn_infos{juju_model=\"$juju_model\", ip!=\"\"}) > bool 0",
          "legendFormat": "tunnel",
          "refId": "A"
        }
      ],
      "fieldConfig": {
