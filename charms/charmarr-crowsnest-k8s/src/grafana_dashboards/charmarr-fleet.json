    {
      "id": 140,
      "type": "row",
      "title": "Data path",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 43,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 141,
      "type": "timeseries",
      "title": "Download throughput (qbit + sab)",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 0,
        "y": 44,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(qbittorrent_dl_info_data_bytes_total{juju_model=\"$juju_model\"}[5m]))",
          "legendFormat": "qbittorrent download",
          "refId": "A"
        },
        {
          "expr": "sum(rate(qbittorrent_up_info_data_bytes_total{juju_model=\"$juju_model\"}[5m]))",
