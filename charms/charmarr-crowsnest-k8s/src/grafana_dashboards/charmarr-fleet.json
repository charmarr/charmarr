        "w": 6,
        "h": 9
      },
      "targets": [
        {
          "expr": "sum(charmarr_requests_total{juju_model=\"$juju_model\", status=\"available\"}) / clamp_min(sum(charmarr_requests_total{juju_model=\"$juju_model\", status=~\"approved|processing|available\"}), 1)",
