{
  "title": "Charmarr Fleet",
  "uid": "charmarr-fleet",
  "tags": [
    "charmarr",
    "fleet",
    "crowsnest"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "",
  "style": "dark",
  "templating": {
    "list": [
      {
        "name": "juju_model",
        "label": "Model",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${prometheusds}"
        },
        "query": "label_values(up{juju_charm=~\"(radarr|sonarr|prowlarr|qbittorrent|sabnzbd|plex|gluetun|flaresolverr|seerr|charmarr-storage|charmarr-crowsnest)-k8s\"}, juju_model)",
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "hide": 0
      },
      {
        "name": "nodegraphds",
        "label": "Node Graph datasource",
        "type": "datasource",
        "query": "hamedkarbasi93-nodegraphapi-datasource",
        "current": {"selected": false, "text": "default", "value": "default"},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 101,
      "type": "gauge",
      "title": "Stack Up",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "expr": "sum(up{juju_model=\"$juju_model\", juju_charm=~\"(radarr|sonarr|prowlarr|qbittorrent|sabnzbd|plex|gluetun|flaresolverr|seerr|charmarr-storage|charmarr-crowsnest)-k8s\"} == 1) / count(up{juju_model=\"$juju_model\", juju_charm=~\"(radarr|sonarr|prowlarr|qbittorrent|sabnzbd|plex|gluetun|flaresolverr|seerr|charmarr-storage|charmarr-crowsnest)-k8s\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.6
              },
              {
                "color": "yellow",
                "value": 0.85
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "sizing": "manual",
        "minVizWidth": 75,
        "minVizHeight": 75,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        }
      }
    },
    {
      "id": 102,
      "type": "stat",
      "title": "VPN tunnel",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "expr": "count(gluetun_vpn_infos{juju_model=\"$juju_model\", ip!=\"\"}) > bool 0",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "TUNNEL DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "TUNNEL UP",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        }
      }
    },
    {
      "id": 103,
      "type": "stat",
      "title": "Request fulfillment",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "expr": "sum(charmarr_requests_total{juju_model=\"$juju_model\", status=\"available\"}) / clamp_min(sum(charmarr_requests_total{juju_model=\"$juju_model\", status=~\"approved|processing|available\"}), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.85
              },
              {
                "color": "green",
                "value": 0.95
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        }
      }
    },
    {
      "id": 104,
      "type": "stat",
      "title": "Download throughput",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "expr": "sum(rate(qbittorrent_dl_info_data_bytes_total{juju_model=\"$juju_model\"}[5m])) + sum(rate(sabnzbd_download_bytes_total{juju_model=\"$juju_model\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        }
      }
    },
    {
      "id": 110,
      "type": "row",
      "title": "Heartbeat",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 111,
      "type": "status-history",
      "title": "Per-app uptime",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 24,
        "h": 12
      },
      "targets": [
        {
          "expr": "min by (juju_application) (min_over_time(up{juju_model=\"$juju_model\", juju_charm=~\"(radarr|sonarr|prowlarr|qbittorrent|sabnzbd|plex|gluetun|flaresolverr|seerr|charmarr-storage|charmarr-crowsnest)-k8s\"}[$__interval]))",
          "legendFormat": "{{juju_application}}",
          "interval": "2m",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 100
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {"text": "down", "color": "red"},
                "1": {"text": "up", "color": "green"}
              }
            }
          ],
          "noValue": "no data"
        },
        "overrides": []
      },
      "options": {
        "showValue": "never",
        "rowHeight": 0.8,
        "colWidth": 0.8,
        "legend": {
          "showLegend": false,
          "displayMode": "list",
          "placement": "right"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 120,
      "type": "row",
      "title": "Topology",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 121,
      "type": "nodeGraph",
      "title": "Charmarr fleet relation graph",
      "description": "Live relation graph for the charmarr fleet. Each node is a charm; arcs around a node show its relation health, edges are bound relations labeled by interface.",
      "datasource": {
        "type": "hamedkarbasi93-nodegraphapi-datasource",
        "uid": "${nodegraphds}"
      },
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 18,
        "h": 14
      },
      "targets": [
        {
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "arc__bound"},
            "properties": [
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "arc__missing"},
            "properties": [
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "arc__optional"},
            "properties": [
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}
            ]
          }
        ]
      },
      "options": {
        "nodes": {
          "mainStatUnit": "short",
          "secondaryStatUnit": "short",
          "arcs": [
            {"field": "arc__bound", "color": "green"},
            {"field": "arc__missing", "color": "red"},
            {"field": "arc__optional", "color": "yellow"}
          ]
        },
        "edges": {
          "mainStatUnit": "short",
          "secondaryStatUnit": "short"
        }
      }
    },
    {
      "id": 122,
      "type": "bargauge",
      "title": "Required relations bound",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 18,
        "y": 6,
        "w": 6,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (juju_application) (charmarr_relation_bound{juju_model=\"$juju_model\", required=\"true\"}) / count by (juju_application) (charmarr_relation_bound{juju_model=\"$juju_model\", required=\"true\"})",
          "legendFormat": "{{juju_application}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 0,
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        }
      }
    },
    {
      "id": 123,
      "type": "stat",
      "title": "Edges in the fleet",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 18,
        "y": 13,
        "w": 6,
        "h": 7
      },
      "targets": [
        {
          "expr": "count(charmarr_relation_edge{juju_model=\"$juju_model\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        }
      }
    },
    {
      "id": 130,
      "type": "row",
      "title": "Request funnel (seerr)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 33,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 131,
      "type": "piechart",
      "title": "Requests by status",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 0,
        "y": 34,
        "w": 8,
        "h": 9
      },
      "targets": [
        {
          "expr": "max by (status) (charmarr_requests_total{juju_model=\"$juju_model\", status=~\"pending|approved|processing|available|declined\"})",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "available"
              },
              "properties": [
                {
                  "id": "color",
                  "value": {
                    "mode": "fixed",
                    "fixedColor": "green"
                  }
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "declined"
              },
              "properties": [
                {
                  "id": "color",
                  "value": {
                    "mode": "fixed",
                    "fixedColor": "red"
                  }
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "pending"
              },
              "properties": [
                {
                  "id": "color",
                  "value": {
                    "mode": "fixed",
                    "fixedColor": "yellow"
                  }
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "approved"
              },
              "properties": [
                {
                  "id": "color",
                  "value": {
                    "mode": "fixed",
                    "fixedColor": "blue"
                  }
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "processing"
              },
              "properties": [
                {
                  "id": "color",
                  "value": {
                    "mode": "fixed",
                    "fixedColor": "purple"
                  }
                }
              ]
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "pieType": "donut",
        "displayLabels": [
          "percent",
          "name"
        ],
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "right",
          "values": [
            "value"
          ]
        },
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 132,
      "type": "timeseries",
      "title": "Request bucket trends",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 8,
        "y": 34,
        "w": 10,
        "h": 9
      },
      "targets": [
        {
          "expr": "max by (status) (charmarr_requests_total{juju_model=\"$juju_model\", status=~\"pending|approved|processing|available|declined\"})",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
