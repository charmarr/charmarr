{
  "title": "qBittorrent",
  "uid": "charmarr-qbittorrent",
  "tags": ["charmarr", "qbittorrent"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "",
  "templating": {
    "list": [
      {
        "name": "juju_model",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
        "query": "label_values(up{juju_charm=\"qbittorrent-k8s\"}, juju_model)",
        "refresh": 1, "includeAll": false, "multi": false
      },
      {
        "name": "juju_application",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
        "query": "label_values(up{juju_charm=\"qbittorrent-k8s\", juju_model=\"$juju_model\"}, juju_application)",
        "refresh": 1, "includeAll": false, "multi": false
      },
      {
        "name": "juju_unit",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
        "query": "label_values(up{juju_charm=\"qbittorrent-k8s\", juju_model=\"$juju_model\", juju_application=\"$juju_application\"}, juju_unit)",
        "refresh": 1, "includeAll": true, "multi": true
      }
    ]
  },
  "panels": [
    {"id": 1, "type": "row", "title": "Service health", "collapsed": false, "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}},

    {
      "id": 2, "type": "stat", "title": "Workload reachable",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 0, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "min(up{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}}}, {"type": "value", "options": {"1": {"text": "UP", "color": "green"}}}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}},
      "options": {"colorMode": "background", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 3, "type": "stat", "title": "Download speed",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 4, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(qbittorrent_global_dl_speed_bytes{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "binBps"}},
      "options": {"colorMode": "value", "graphMode": "area", "textMode": "value"}
    },
    {
      "id": 4, "type": "stat", "title": "Upload speed",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 8, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(qbittorrent_global_ul_speed_bytes{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "binBps"}},
      "options": {"colorMode": "value", "graphMode": "area", "textMode": "value"}
    },
    {
      "id": 5, "type": "stat", "title": "Global ratio",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 12, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "qbittorrent_global_alltime_ul_bytes{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"} / qbittorrent_global_alltime_dl_bytes{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"}", "refId": "A"}],
      "fieldConfig": {"defaults": {"decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "green", "value": 1.0}]}}},
      "options": {"colorMode": "value", "graphMode": "area", "textMode": "value"}
    },
    {
      "id": 6, "type": "stat", "title": "Log volume (5m)",
      "datasource": {"type": "loki", "uid": "${lokids}"},
      "gridPos": {"x": 16, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(count_over_time({juju_model=\"$juju_model\", juju_application=\"$juju_application\"}[5m]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}},
      "options": {"colorMode": "value", "graphMode": "area", "textMode": "value"}
    },
    {
      "id": 7, "type": "stat", "title": "Errors in logs (1h)",
      "datasource": {"type": "loki", "uid": "${lokids}"},
      "gridPos": {"x": 20, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(count_over_time({juju_model=\"$juju_model\", juju_application=\"$juju_application\"} |~ \"(?i)error|fatal\" [1h]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 100}]}}},
      "options": {"colorMode": "value", "graphMode": "area", "textMode": "value"}
    },

    {"id": 10, "type": "row", "title": "Transfer activity", "collapsed": false, "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1}},

    {
      "id": 11, "type": "timeseries", "title": "Download speed over time",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 8},
      "targets": [{"expr": "sum(qbittorrent_global_dl_speed_bytes{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "legendFormat": "DL", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "binBps"}},
      "options": {"legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 12, "type": "timeseries", "title": "Upload speed over time",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 8},
      "targets": [{"expr": "sum(qbittorrent_global_ul_speed_bytes{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "legendFormat": "UL", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "binBps"}},
      "options": {"legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 13, "type": "stat", "title": "Peer connections",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 0, "y": 14, "w": 8, "h": 4},
      "targets": [{"expr": "sum(qbittorrent_global_total_peer_connections{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "refId": "A"}],
      "options": {"colorMode": "value", "graphMode": "area", "textMode": "value"}
    },
    {
      "id": 14, "type": "stat", "title": "All-time downloaded",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 8, "y": 14, "w": 8, "h": 4},
      "targets": [{"expr": "sum(qbittorrent_global_alltime_dl_bytes{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "options": {"colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 15, "type": "stat", "title": "All-time uploaded",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 16, "y": 14, "w": 8, "h": 4},
      "targets": [{"expr": "sum(qbittorrent_global_alltime_ul_bytes{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "options": {"colorMode": "value", "graphMode": "none", "textMode": "value"}
    },

    {"id": 20, "type": "row", "title": "Torrent breakdown", "collapsed": false, "gridPos": {"x": 0, "y": 18, "w": 24, "h": 1}},

    {
      "id": 21, "type": "stat", "title": "Total torrents",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 0, "y": 19, "w": 4, "h": 4},
      "targets": [{"expr": "sum(qbittorrent_torrents_count{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "refId": "A"}],
      "options": {"colorMode": "value", "graphMode": "area", "textMode": "value"}
    },
    {
      "id": 22, "type": "stat", "title": "Downloading",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 4, "y": 19, "w": 4, "h": 4},
      "targets": [{"expr": "sum(qbittorrent_torrents_count{state=\"downloading\", juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "refId": "A"}],
      "options": {"colorMode": "value", "graphMode": "area", "textMode": "value"}
    },
    {
      "id": 23, "type": "stat", "title": "Seeding",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 8, "y": 19, "w": 4, "h": 4},
      "targets": [{"expr": "sum(qbittorrent_torrents_count{state=~\"uploading|stalledUP\", juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "refId": "A"}],
      "options": {"colorMode": "value", "graphMode": "area", "textMode": "value"}
    },
    {
      "id": 24, "type": "stat", "title": "Errored",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 12, "y": 19, "w": 4, "h": 4},
      "targets": [{"expr": "sum(qbittorrent_torrents_count{state=~\"error|missingFiles\", juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}}},
      "options": {"colorMode": "background", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 25, "type": "timeseries", "title": "Torrents by state over time",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 16, "y": 19, "w": 8, "h": 8},
      "targets": [{"expr": "sum by (state) (qbittorrent_torrents_count{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "legendFormat": "{{state}}", "refId": "A"}],
      "options": {"legend": {"showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["last"]}}
    },

    {"id": 30, "type": "row", "title": "Categories and tags", "collapsed": false, "gridPos": {"x": 0, "y": 27, "w": 24, "h": 1}},

    {
      "id": 31, "type": "piechart", "title": "Torrents by category",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 0, "y": 28, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (category) (qbittorrent_torrents_count{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "legendFormat": "{{category}}", "refId": "A"}],
      "options": {"legend": {"showLegend": true, "placement": "right"}, "pieType": "donut"}
    },
    {
      "id": 32, "type": "piechart", "title": "Torrents by tag (top 10)",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 12, "y": 28, "w": 12, "h": 8},
      "targets": [{"expr": "topk(10, sum by (tag) (qbittorrent_torrents_count{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"}))", "legendFormat": "{{tag}}", "refId": "A"}],
      "options": {"legend": {"showLegend": true, "placement": "right"}, "pieType": "donut"}
    },

    {"id": 40, "type": "row", "title": "Top torrents", "collapsed": false, "gridPos": {"x": 0, "y": 36, "w": 24, "h": 1}},

    {
      "id": 41, "type": "table", "title": "Top 10 torrents by download speed",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 0, "y": 37, "w": 24, "h": 8},
      "targets": [{"expr": "topk(10, qbittorrent_torrent_download_speed_bytes{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "format": "table", "instant": true, "refId": "A"}],
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "instance": true, "job": true, "juju_charm": true, "juju_model_uuid": true, "juju_model": true, "juju_application": true, "juju_unit": true, "hash": true}, "renameByName": {"name": "Name", "category": "Category", "Value": "DL speed (B/s)"}}}
      ],
      "fieldConfig": {"defaults": {}, "overrides": [{"matcher": {"id": "byName", "options": "DL speed (B/s)"}, "properties": [{"id": "unit", "value": "binBps"}]}]}
    },

    {"id": 60, "type": "row", "title": "Logs", "collapsed": false, "gridPos": {"x": 0, "y": 45, "w": 24, "h": 1}},

    {
      "id": 61, "type": "logs", "title": "ERROR/WARN log lines (qBittorrent + exporter)",
      "datasource": {"type": "loki", "uid": "${lokids}"},
      "gridPos": {"x": 0, "y": 46, "w": 24, "h": 10},
      "targets": [{"expr": "{juju_model=\"$juju_model\", juju_application=\"$juju_application\"} |~ \"(?i)error|warn|fatal\"", "refId": "A"}],
      "options": {"showTime": true, "showLabels": false, "wrapLogMessage": true, "sortOrder": "Descending"}
    }
  ]
}
