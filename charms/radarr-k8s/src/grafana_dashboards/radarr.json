{
  "title": "Radarr",
  "uid": "charmarr-radarr",
  "tags": [
    "charmarr",
    "radarr"
  ],
  "schemaVersion": 39,
  "version": 4,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "",
  "templating": {
    "list": [
      {
        "name": "juju_model",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${prometheusds}"
        },
        "query": "label_values(up{juju_charm=\"radarr-k8s\"}, juju_model)",
        "refresh": 1,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "juju_application",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${prometheusds}"
        },
        "query": "label_values(up{juju_charm=\"radarr-k8s\", juju_model=\"$juju_model\"}, juju_application)",
        "refresh": 1,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "juju_unit",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${prometheusds}"
        },
        "query": "label_values(up{juju_charm=\"radarr-k8s\", juju_model=\"$juju_model\", juju_application=\"$juju_application\"}, juju_unit)",
        "refresh": 1,
        "includeAll": true,
        "multi": true
      },
      {
        "name": "path",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${prometheusds}"
        },
        "query": "label_values(radarr_free_disk_size{juju_model=\"$juju_model\", juju_application=\"$juju_application\"}, path)",
        "refresh": 1,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Service health",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Workload reachable",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "min(up{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Items in queue",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(radarr_queue_count{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 20
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Last scrape age",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "time() - max(radarr_last_scrape{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 120
              },
              {
                "color": "red",
                "value": 300
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Scrape p95 (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "quantile_over_time(0.95, radarr_scrape_duration{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"}[1h])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 30
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Log volume (5m)",
      "datasource": {
        "type": "loki",
        "uid": "${lokids}"
      },
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(count_over_time({juju_model=\"$juju_model\", juju_application=\"$juju_application\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Errors in logs (1h)",
      "datasource": {
        "type": "loki",
        "uid": "${lokids}"
      },
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(count_over_time({juju_model=\"$juju_model\", juju_application=\"$juju_application\"} |~ \"(?i)error|fatal\" [1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Library inventory",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Total movies",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(radarr_movies_total{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Monitored",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(radarr_monitored_movies_total{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Unmonitored",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 4,
        "y": 6,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(radarr_unmonitored_movies_total{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Missing",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 4,
        "y": 10,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(radarr_missing_movies_total{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Library status breakdown",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 8,
        "y": 6,
        "w": 16,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(radarr_announced_movies_total{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})",
          "legendFormat": "announced",
          "refId": "A"
        },
        {
          "expr": "sum(radarr_in_cinemas_movies_total{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})",
          "legendFormat": "in cinemas",
          "refId": "B"
        },
        {
          "expr": "sum(radarr_released_movies_total{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})",
          "legendFormat": "released",
          "refId": "C"
        },
        {
          "expr": "sum(radarr_tba_movies_total{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})",
          "legendFormat": "tba",
          "refId": "D"
        },
        {
          "expr": "sum(radarr_deleted_movies_total{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})",
          "legendFormat": "deleted",
          "refId": "E"
        }
      ],
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "last"
          ]
        }
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Queue activity",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Queue depth",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (juju_unit) (radarr_queue_count{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})",
          "legendFormat": "{{juju_unit}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Queue errors and warnings (stacked)",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 12,
        "y": 15,
        "w": 12,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(radarr_queue_error{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})",
          "legendFormat": "errors",
          "refId": "A"
        },
        {
          "expr": "sum(radarr_queue_warning{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})",
          "legendFormat": "warnings",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 50
          }
        }
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 23,
      "type": "stat",
      "title": "Queue depth (now)",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 12,
        "y": 19,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(radarr_queue_count{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 24,
      "type": "stat",
      "title": "Queue errors (now)",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 16,
        "y": 19,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(radarr_queue_error{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 25,
      "type": "stat",
      "title": "Queue warnings (now)",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 20,
        "y": 19,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(radarr_queue_warning{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 60,
      "type": "table",
      "title": "Active downloads",
      "description": "Items currently in radarr's queue (charm-emitted via /api/v3/queue). Sorted by bytes remaining so the biggest in-flight items float to the top.",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 0, "y": 23, "w": 24, "h": 8},
      "targets": [
        {
          "expr": "charmarr_queue_item_size_bytes{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "charmarr_queue_item_remaining_bytes{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"}",
          "format": "table",
          "instant": true,
          "refId": "B"
        }
      ],
      "transformations": [
        {"id": "joinByField", "options": {"byField": "title", "mode": "outer"}},
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true, "Time 2": true,
              "__name__ 1": true, "__name__ 2": true,
              "instance 1": true, "instance 2": true,
              "job 1": true, "job 2": true,
              "juju_charm 1": true, "juju_charm 2": true,
              "juju_model 1": true, "juju_model 2": true,
              "juju_model_uuid 1": true, "juju_model_uuid 2": true,
              "juju_application 1": true, "juju_application 2": true,
              "juju_unit 1": true, "juju_unit 2": true,
              "status 2": true, "protocol 2": true
            },
            "renameByName": {
              "title": "Title",
              "status 1": "Status",
              "protocol 1": "Protocol",
              "Value #A": "Size",
              "Value #B": "Remaining"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "bytes"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Title"}, "properties": [{"id": "unit", "value": "string"}, {"id": "custom.width", "value": 420}]},
          {"matcher": {"id": "byName", "options": "Status"}, "properties": [{"id": "unit", "value": "string"}, {"id": "custom.width", "value": 120}]},
          {"matcher": {"id": "byName", "options": "Protocol"}, "properties": [{"id": "unit", "value": "string"}, {"id": "custom.width", "value": 100}]}
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{"displayName": "Remaining", "desc": true}],
        "footer": {"show": false}
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "Storage",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 31,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Free space per root folder",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "radarr_free_disk_size{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\", path=~\"$path\"}",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "last"
          ]
        }
      }
    },
    {
      "id": 32,
      "type": "bargauge",
      "title": "Filesystem used percentage",
      "description": "Used fraction of the underlying filesystem (capacity minus free), aggregated per unit. `radarr_disk_size_total` is media-stored bytes, not capacity — capacity comes from `radarr_available_disk_size`.",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 12,
        "y": 32,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "(max by (juju_unit) (radarr_available_disk_size{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"}) - max by (juju_unit) (radarr_free_disk_size{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})) / max by (juju_unit) (radarr_available_disk_size{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"}) * 100",
          "legendFormat": "{{juju_unit}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      }
    },
    {
      "id": 40,
      "type": "row",
      "title": "Content breakdown",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 40,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 41,
      "type": "piechart",
      "title": "Movies by quality",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 0,
        "y": 41,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (quality) (radarr_quality_movies_total{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})",
          "legendFormat": "{{quality}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "right"
        },
        "pieType": "donut"
      }
    },
    {
      "id": 42,
      "type": "piechart",
      "title": "Movies by genre (top 10)",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 12,
        "y": 41,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(10, sum by (genre) (radarr_genres_count_total{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"}))",
          "legendFormat": "{{genre}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "right"
        },
        "pieType": "donut"
      }
    },
    {
      "id": 50,
      "type": "row",
      "title": "Throughput trends",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 49,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 51,
      "type": "timeseries",
      "title": "Movies added rate (per 1d)",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 0,
        "y": 50,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "delta(sum(radarr_movies_total{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})[1d:1h])",
          "legendFormat": "added/day",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 52,
      "type": "timeseries",
      "title": "Missing movies (30d)",
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheusds}"
      },
      "gridPos": {
        "x": 12,
        "y": 50,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(radarr_missing_movies_total{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})",
          "legendFormat": "missing",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 60,
      "type": "row",
      "title": "Logs",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 58,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 61,
      "type": "logs",
      "title": "ERROR/WARN log lines (Radarr + scraparr)",
      "datasource": {
        "type": "loki",
        "uid": "${lokids}"
      },
      "gridPos": {
        "x": 0,
        "y": 59,
        "w": 24,
        "h": 10
      },
      "targets": [
        {
          "expr": "{juju_model=\"$juju_model\", juju_application=\"$juju_application\"} |~ \"(?i)error|warn|fatal\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }
  ]
}