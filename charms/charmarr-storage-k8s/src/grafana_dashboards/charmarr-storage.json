{
  "title": "Charmarr Storage",
  "uid": "charmarr-storage",
  "tags": ["charmarr", "storage"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "",
  "templating": {
    "list": [
      {
        "name": "juju_model",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
        "query": "label_values(up{juju_charm=\"charmarr-storage-k8s\"}, juju_model)",
        "refresh": 1, "includeAll": false, "multi": false
      },
      {
        "name": "juju_application",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
        "query": "label_values(up{juju_charm=\"charmarr-storage-k8s\", juju_model=\"$juju_model\"}, juju_application)",
        "refresh": 1, "includeAll": false, "multi": false
      },
      {
        "name": "juju_unit",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
        "query": "label_values(up{juju_charm=\"charmarr-storage-k8s\", juju_model=\"$juju_model\", juju_application=\"$juju_application\"}, juju_unit)",
        "refresh": 1, "includeAll": true, "multi": true
      }
    ]
  },
  "panels": [
    {"id": 1, "type": "row", "title": "Storage broker health", "collapsed": false, "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}},

    {
      "id": 2, "type": "stat", "title": "Charm reachable",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 0, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "min(up{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}},
      "options": {"colorMode": "background", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 3, "type": "stat", "title": "PVC state",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 4, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "min(charmarr_storage_pvc_bound{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "UNBOUND", "color": "red"}, "1": {"text": "BOUND", "color": "green"}}}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}},
      "options": {"colorMode": "background", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 4, "type": "stat", "title": "Permission check",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 8, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "min(charmarr_storage_permission_check_ok{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"-1": {"text": "PENDING", "color": "yellow"}, "0": {"text": "FAILED", "color": "red"}, "1": {"text": "OK", "color": "green"}}}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": -0.5}, {"color": "green", "value": 0.5}]}}},
      "options": {"colorMode": "background", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 5, "type": "stat", "title": "Consumers bound",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 12, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "max(charmarr_storage_consumers_total{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 1}, {"color": "green", "value": 2}]}}},
      "options": {"colorMode": "value", "graphMode": "area", "textMode": "value"}
    },
    {
      "id": 6, "type": "stat", "title": "Requested capacity",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 16, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "max(charmarr_storage_pvc_capacity_bytes{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "options": {"colorMode": "value", "graphMode": "area", "textMode": "value"}
    },
    {
      "id": 7, "type": "stat", "title": "Backend",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 20, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "max by (backend) (charmarr_storage_pvc_bound{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "legendFormat": "{{backend}}", "refId": "A"}],
      "fieldConfig": {"defaults": {}},
      "options": {"colorMode": "none", "graphMode": "none", "textMode": "name", "reduceOptions": {"calcs": ["lastNotNull"], "fields": ""}}
    },

    {"id": 10, "type": "row", "title": "Capacity and consumers", "collapsed": false, "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1}},

    {
      "id": 11, "type": "timeseries", "title": "Requested PVC capacity",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 8},
      "targets": [{"expr": "max by (backend) (charmarr_storage_pvc_capacity_bytes{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "legendFormat": "{{backend}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "options": {"legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 12, "type": "timeseries", "title": "Consumers bound over time",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 8},
      "targets": [{"expr": "max(charmarr_storage_consumers_total{juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"})", "legendFormat": "consumers", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}},
      "options": {"legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"}}
    },

    {"id": 20, "type": "row", "title": "Topology", "collapsed": false, "gridPos": {"x": 0, "y": 14, "w": 24, "h": 1}},

    {
      "id": 21, "type": "table", "title": "Bound consumers (from charmarr_relation_edge)",
      "datasource": {"type": "prometheus", "uid": "${prometheusds}"},
      "gridPos": {"x": 0, "y": 15, "w": 24, "h": 8},
      "targets": [{"expr": "charmarr_relation_edge{relation=\"media-storage\", juju_model=\"$juju_model\", juju_application=\"$juju_application\", juju_unit=~\"$juju_unit\"}", "format": "table", "instant": true, "refId": "A"}],
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "Value": true, "__name__": true, "instance": true, "job": true, "juju_charm": true, "juju_model_uuid": true, "relation": true, "juju_unit": true, "juju_application": true, "juju_model": true}, "renameByName": {"from_app": "Consumer", "to_app": "Storage broker"}}}
      ]
    },

    {"id": 60, "type": "row", "title": "Logs", "collapsed": false, "gridPos": {"x": 0, "y": 23, "w": 24, "h": 1}},

    {
      "id": 61, "type": "logs", "title": "ERROR/WARN log lines",
      "datasource": {"type": "loki", "uid": "${lokids}"},
      "gridPos": {"x": 0, "y": 24, "w": 24, "h": 10},
      "targets": [{"expr": "{juju_model=\"$juju_model\", juju_application=\"$juju_application\"} |~ \"(?i)error|warn|fatal\"", "refId": "A"}],
      "options": {"showTime": true, "showLabels": false, "wrapLogMessage": true, "sortOrder": "Descending"}
    }
  ]
}
